# SQLite production-like setup (recommended with Node.js LTS v20)
NODE_ENV=production
PORT=3000

# Storage
STORAGE_DRIVER=sqlite
DB_PATH=storage/gatelaunch.db
# In production, keep this false so the app fails loudly if SQLite isn't available.
ALLOW_SQLITE_FALLBACK=false

# Security / OWASP
TRUST_PROXY=false
COOKIE_SECURE=auto
ALLOWED_ORIGINS=
API_RATE_MAX=300
API_RATE_WINDOW_MS=900000

# Admin bootstrap (required for first secure admin login)
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
DEMO_SEED_USERS=false

