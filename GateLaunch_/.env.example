PORT=3000
NODE_ENV=development
TRUST_PROXY=false
COOKIE_SECURE=auto
ALLOWED_ORIGINS=
API_RATE_MAX=300
API_RATE_WINDOW_MS=900000
STORAGE_DRIVER=json
ALLOW_SQLITE_FALLBACK=true
DB_PATH=storage/gatelaunch.db
STORAGE_BACKUP_ENABLED=true
STORAGE_BACKUP_INTERVAL_MS=86400000
STORAGE_BACKUP_DIR=storage/backups
STORAGE_BACKUP_ON_STARTUP=true

# One-time bootstrap admin account (required for first secure admin login)
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
DEMO_SEED_USERS=true

# Audit log cap (in-memory stored in data.json/sqlite as well; trimmed to this max)
AUDIT_LOG_MAX=1500

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack Incoming Webhook
SLACK_WEBHOOK_URL=

# Generic Admin Webhook
ADMIN_WEBHOOK_URL=
ADMIN_WEBHOOK_SECRET=

# n8n Webhook Integration
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_TIMEOUT_MS=15000

# AI Sync Engine
AI_SYNC_ENABLED=true
AI_SYNC_INTERVAL_MS=300000

# Payments
PAYMENTS_ENABLED=false
PAYMENTS_PROVIDER=stripe
PAYMENT_CURRENCY=egp
# Stripe keys (server-side)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Redirect URLs for Stripe Checkout (must be absolute URLs)
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard.html#payments
STRIPE_CANCEL_URL=http://localhost:3000/dashboard.html#game-charge

# Economy / Wheel
# Earned currency: 1 Shengen per active hour (default).
ECONOMY_RATE_PER_HOUR=1
# Safety cap for heartbeat credit per minute tick (ms).
ECONOMY_MAX_HEARTBEAT_CREDIT_MS=70000
# Wheel cooldown (ms) - default: 1h.
WHEEL_SPIN_COOLDOWN_MS=3600000
# Keep exactly 6 segments to match the current UI wheel rendering: amount:weight,...
WHEEL_SEGMENTS=0:20,1:25,2:20,3:15,5:12,10:8
